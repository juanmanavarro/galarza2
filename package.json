{
  "name": "galarza2",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "concurrently -k -n nuxt,mail \"nuxt dev\" \"npm run mail-server\"",
    "mail-server": "PYTHONUNBUFFERED=1 python3 local-mail-server.py",
    "generate": "nuxt generate && cp mail.php .output/public/mail.php",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "flyonui": "^2.4.1",
    "nuxt": "^4.2.2",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "autoprefixer": "^10.4.23",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "vitest": "^4.0.15"
  }
}
