#
# SMTP Configuration for mail.php
# Copy this file to .env and fill in your credentials
#
# If SMTP_PASS is empty or SMTP fails, the PHP script falls
# back to PHP's mail() function (for Plesk production).
# The Python local server will log emails to console instead.
#

# SMTP_PASS is optional. If set, both PHP and Python will try SMTP first.
# If empty or fails, PHP uses mail(), Python logs to console.
SMTP_PASS=

MAIL_TO=configurador@industriasgalarza.com
MAIL_FROM=configurador@industriasgalarza.com

# For Microsoft 365 / Outlook:
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=configurador@industriasgalarza.com
