#
# SMTP Configuration for mail.php
# Copy this file to .env and fill in your credentials
#

# MAIL_TO defaults to services@juanmanavar.ro in local dev
# In production, set it to configurador@industriasgalarza.com
MAIL_TO=services@juanmanavar.ro
MAIL_FROM=configurador@industriasgalarza.com

SMTP_HOST=industriasgalarza.com
SMTP_PORT=465
SMTP_SECURE=ssl

SMTP_USER=configurador@industriasgalarza.com
SMTP_PASS=
